# CTE Environment Variables
# Copy to .env and fill in real values

# ── System Mode (Python services / CLI) ─────────────────────
# seed  = UI preview with fake data
# paper = live public market data + simulated fills (no prod orders)
# demo  = live market + Binance FUTURES TESTNET orders (keys required)
# live  = DISABLED in v1
CTE_ENGINE_MODE=paper

# ── Dashboard container only (Docker Compose `analytics` service) ──
# Overrides CTE_ENGINE_MODE for the UI process. See docs/DASHBOARD_MODES.md
# seed  = fake trades, NO WebSocket (works behind strict firewalls)
# paper = default — Binance public combined stream BTC/ETH (no API keys)
# demo  = requires CTE_BINANCE_TESTNET_* below or container exits
# CTE_DASHBOARD_MODE=paper

# Optional: override Binance futures combined stream URL (paper/demo)
# CTE_MARKET_WS_URL=wss://fstream.binance.com/stream

CTE_ENGINE_LOG_LEVEL=INFO

# ── Redis ─────────────────────────────────────────────────────
CTE_REDIS_URL=redis://localhost:6379/0

# ── Database ──────────────────────────────────────────────────
CTE_DB_HOST=localhost
CTE_DB_PORT=5432
CTE_DB_NAME=cte
CTE_DB_USER=cte
CTE_DB_PASSWORD=

# ── Execution ─────────────────────────────────────────────────
CTE_EXECUTION_MODE=paper

# ── Binance Testnet (required when CTE_ENGINE_MODE=demo or CTE_DASHBOARD_MODE=demo) ──
# Get keys from: https://testnet.binancefuture.com
# CTE_BINANCE_TESTNET_API_KEY=
# CTE_BINANCE_TESTNET_API_SECRET=
# CTE_BINANCE_TESTNET_REST_URL=https://testnet.binancefuture.com

# ── Bybit Demo (optional for demo mode) ──────────────────────
# Get keys from: https://testnet.bybit.com
# CTE_BYBIT_DEMO_API_KEY=your_demo_api_key_here
# CTE_BYBIT_DEMO_API_SECRET=your_demo_api_secret_here

# ── Context Data (optional) ──────────────────────────────────
# CTE_WHALE_ALERT_API_KEY=
# CTE_ETHERSCAN_API_KEY=

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
