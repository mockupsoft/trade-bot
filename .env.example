# CTE Environment Variables
# Copy to `.env` and fill in real values (`.env` is gitignored).
# The dashboard (`python -m cte.dashboard` / `cte-dashboard`) loads repo-root `.env` into the process environment on startup.

# ── Binance futures testnet (required for dashboard) ─────────
CTE_BINANCE_TESTNET_API_KEY=
CTE_BINANCE_TESTNET_API_SECRET=
CTE_BINANCE_TESTNET_REST_URL=https://testnet.binancefuture.com

# Optional: market combined WebSocket (default: testnet)
# CTE_BINANCE_WS_COMBINED_URL=wss://stream.binancefuture.com/stream

# ── Process mode ──────────────────────────────────────────────
# Microservices (connectors, execution, …): paper + simulated fills.
CTE_ENGINE_MODE=paper
CTE_EXECUTION_MODE=paper
# Dashboard real testnet orders: set demo engine + testnet execution, then optional:
# CTE_DASHBOARD_VENUE_LOOP=1
# Full lifecycle proof (see docs/TESTNET_E2E_PROOF_REPORT.md):
#   python3 scripts/verify_binance_testnet_auth.py
#   python3 scripts/run_testnet_e2e_proof.py
# Optional: override trading universe (JSON array). If you still have only
# ["BTCUSDT","ETHUSDT"], the dashboard expands that legacy pair to the full
# default 10 in ``cte.core.universe``. To force exactly two symbols, list a
# third pair you do not trade or manage via Ops toggles.
# CTE_ENGINE_SYMBOLS=["BTCUSDT","ETHUSDT","BNBUSDT","SOLUSDT",...]

# When running ONLY the dashboard locally, use demo + keys above:
#   CTE_ENGINE_MODE=demo cte-dashboard
# Docker `analytics` service sets demo in compose; keys still required.
# Optional: set CTE_DASHBOARD_DUAL_STACK=0 to force legacy IPv4-only bind (0.0.0.0).

# In-dashboard paper loop (Positions tab): default demo mode shortens warmup and tier-C floor.
# CTE_DASHBOARD_PAPER_DEMO_ENTRIES=0  # strict (80 mids, tier C 0.40 from config)
# CTE_DASHBOARD_PAPER_WARMUP_MIDS=50    # override mid-count before warmup gate
# CTE_DASHBOARD_PAPER_TIER_C_THRESHOLD=0.36

CTE_ENGINE_LOG_LEVEL=INFO

# Dashboard testnet reconciliation (venue vs local mirror):
# CTE_RECON_STRICT_VALIDATION=1   # exact qty match (tolerance 0); use for clean-account / 24h validation
# CTE_ALLOW_FOREIGN_POSITIONS=0   # default safety: block validation/trading on startup foreign venue positions
#                                # set to 1 only for explicit override (logs warning)
# CTE_RECON_QTY_TOLERANCE_PCT=0.01   # relative tolerance when strict off (default 0.01)
# CTE_RECON_PHANTOM_GRACE_SEC=5.0    # PHANTOM_LOCAL grace after entry (see PositionReconciler)

# In-dashboard paper pipeline (default on): testnet book → scoring → risk → paper → journal on close.
# Set to 0 for tests or if you only want market UI without simulated entries.
# CTE_DASHBOARD_PAPER_LOOP=1
#
# Paper loop tuning (dashboard only — does not affect distributed workers):
# Staged warmup (dashboard paper only): early = min mids to pass warmup gate; full = full confidence.
# CTE_DASHBOARD_PAPER_WARMUP_MIDS_EARLY=20
# CTE_DASHBOARD_PAPER_WARMUP_MIDS_FULL=36
# Legacy alias: CTE_DASHBOARD_PAPER_WARMUP_MIDS maps to FULL threshold if FULL is unset.
# CTE_DASHBOARD_PAPER_EARLY_SIZE_MULT=0.35   # notional multiplier for warmup_phase=early entries
# CTE_DASHBOARD_PAPER_INTERVAL_SEC=1.5      # paper loop tick interval (also used for ETA)
# CTE_DASHBOARD_PAPER_STALL_WARN_MINUTES=5   # warn if no entry with healthy feed after this many minutes
# CTE_DASHBOARD_PAPER_TIER_C=0.32      # tier-C floor vs global CTE_SIGNALS_TIER_C_THRESHOLD (0.40)
#
# Paper loop risk: total exposure cap auto-scales with symbol count so up to one
# max-sized LONG per configured symbol can open (dashboard sim only).

# ── Readiness page (dashboard) — attest validation metrics ───
# Live checks: testnet keys + WebSocket. Below are operator/CI attestations:
# CTE_READINESS_PAPER_DAYS=7
# CTE_READINESS_CRASH_FREE_DAYS=7
# CTE_READINESS_TESTS_PASS=1
# CTE_READINESS_FSM_VIOLATIONS=0

# ── Redis ─────────────────────────────────────────────────────
CTE_REDIS_URL=redis://localhost:6379/0

# ── Database ──────────────────────────────────────────────────
CTE_DB_HOST=localhost
CTE_DB_PORT=5432
CTE_DB_NAME=cte
CTE_DB_USER=cte
CTE_DB_PASSWORD=

# ── Bybit Demo (optional) ───────────────────────────────────
# CTE_BYBIT_DEMO_API_KEY=
# CTE_BYBIT_DEMO_API_SECRET=
# CTE_BYBIT_REST_BASE_URL=https://api-demo.bybit.com
# Dashboard venue loop: binance_testnet (default) | bybit_demo
# CTE_DASHBOARD_EXECUTION_VENUE=binance_testnet
# Optional single-symbol venue lock (single-pair proof only). Leave unset or empty so the
# venue loop can place real REST orders on every symbol in the merged dashboard universe
# (see merge_market_feed_symbols + DEFAULT_TRADING_SYMBOLS). Risk/sizing caps still apply.
# CTE_DASHBOARD_VENUE_PROOF_SYMBOL=
# Bybit linear: one_way (positionIdx 0) | hedge (long=1 short=2). Must match account mode in Bybit UI.
# CTE_BYBIT_LINEAR_POSITION_MODE=one_way
# After a filled entry, PHANTOM_LOCAL is classified as transient until this grace elapses (venue position-list lag).
# CTE_RECON_PHANTOM_GRACE_SEC=5
#
# 24h validation: reconciliation expects venue positions to match this runner. Open exposure
# from manual trades or other apps on the same API keys surfaces as phantom_venue and keeps
# recon unclean — use a clean venue account or isolated keys (see dashboard
# /api/paper/status reconciliation.operational_notes).
#
# scripts/smoke_bybit_demo.py — REST smoke only (does not write dashboard analytics)
# CTE_SMOKE_SYMBOL=ADAUSDT
# CTE_SMOKE_DIRECTION=long   # or short — short proves venue path; strategy still long-only

# ── Context Data (optional) ───────────────────────────────────
# CTE_WHALE_ALERT_API_KEY=
# CTE_ETHERSCAN_API_KEY=

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
