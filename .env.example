# CTE Environment Variables
# Copy to .env and fill in real values

# Engine
CTE_ENGINE_MODE=paper
CTE_ENGINE_LOG_LEVEL=INFO

# Redis
CTE_REDIS_URL=redis://localhost:6379/0

# Database
CTE_DB_HOST=localhost
CTE_DB_PORT=5432
CTE_DB_NAME=cte
CTE_DB_USER=cte
CTE_DB_PASSWORD=

# Execution
CTE_EXECUTION_MODE=paper

# Binance (optional: for testnet/live)
# CTE_BINANCE_API_KEY=
# CTE_BINANCE_API_SECRET=

# Whale Alert (optional: context data)
# CTE_WHALE_ALERT_API_KEY=

# Etherscan (optional: context data)
# CTE_ETHERSCAN_API_KEY=

# Grafana
GRAFANA_PASSWORD=admin
