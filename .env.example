# CTE Environment Variables
# Copy to `.env` and fill in real values (`.env` is gitignored).
# The dashboard (`python -m cte.dashboard` / `cte-dashboard`) loads repo-root `.env` into the process environment on startup.

# ── Binance futures testnet (required for dashboard) ─────────
CTE_BINANCE_TESTNET_API_KEY=
CTE_BINANCE_TESTNET_API_SECRET=
CTE_BINANCE_TESTNET_REST_URL=https://testnet.binancefuture.com

# Optional: market combined WebSocket (default: testnet)
# CTE_BINANCE_WS_COMBINED_URL=wss://stream.binancefuture.com/stream

# ── Process mode ──────────────────────────────────────────────
# Microservices (connectors, execution, …): paper + simulated fills.
CTE_ENGINE_MODE=paper
CTE_EXECUTION_MODE=paper

# When running ONLY the dashboard locally, use demo + keys above:
#   CTE_ENGINE_MODE=demo cte-dashboard
# Docker `analytics` service sets demo in compose; keys still required.
# Optional: set CTE_DASHBOARD_DUAL_STACK=0 to force legacy IPv4-only bind (0.0.0.0).

# In-dashboard paper loop (Positions tab): default demo mode shortens warmup and tier-C floor.
# CTE_DASHBOARD_PAPER_DEMO_ENTRIES=0  # strict (80 mids, tier C 0.40 from config)
# CTE_DASHBOARD_PAPER_WARMUP_MIDS=50    # override mid-count before warmup gate
# CTE_DASHBOARD_PAPER_TIER_C_THRESHOLD=0.36

CTE_ENGINE_LOG_LEVEL=INFO

# In-dashboard paper pipeline (default on): testnet book → scoring → risk → paper → journal on close.
# Set to 0 for tests or if you only want market UI without simulated entries.
# CTE_DASHBOARD_PAPER_LOOP=1

# ── Readiness page (dashboard) — attest validation metrics ───
# Live checks: testnet keys + WebSocket. Below are operator/CI attestations:
# CTE_READINESS_PAPER_DAYS=7
# CTE_READINESS_CRASH_FREE_DAYS=7
# CTE_READINESS_TESTS_PASS=1
# CTE_READINESS_FSM_VIOLATIONS=0

# ── Redis ─────────────────────────────────────────────────────
CTE_REDIS_URL=redis://localhost:6379/0

# ── Database ──────────────────────────────────────────────────
CTE_DB_HOST=localhost
CTE_DB_PORT=5432
CTE_DB_NAME=cte
CTE_DB_USER=cte
CTE_DB_PASSWORD=

# ── Bybit Demo (optional) ───────────────────────────────────
# CTE_BYBIT_DEMO_API_KEY=
# CTE_BYBIT_DEMO_API_SECRET=

# ── Context Data (optional) ───────────────────────────────────
# CTE_WHALE_ALERT_API_KEY=
# CTE_ETHERSCAN_API_KEY=

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
