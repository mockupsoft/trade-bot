# CTE Environment Variables
# Copy to .env and fill in real values

# ── System Mode ───────────────────────────────────────────────
# seed  = UI preview with fake data (default)
# paper = live market data + simulated fills
# demo  = live market data + testnet/demo exchange orders
# live  = DISABLED in v1
CTE_ENGINE_MODE=seed

CTE_ENGINE_LOG_LEVEL=INFO

# ── Redis ─────────────────────────────────────────────────────
CTE_REDIS_URL=redis://localhost:6379/0

# ── Database ──────────────────────────────────────────────────
CTE_DB_HOST=localhost
CTE_DB_PORT=5432
CTE_DB_NAME=cte
CTE_DB_USER=cte
CTE_DB_PASSWORD=

# ── Execution ─────────────────────────────────────────────────
CTE_EXECUTION_MODE=paper

# ── Binance Testnet (required for demo mode) ──────────────────
# Get keys from: https://testnet.binancefuture.com
# CTE_BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
# CTE_BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here
# CTE_BINANCE_TESTNET_REST_URL=https://testnet.binancefuture.com

# ── Bybit Demo (optional for demo mode) ──────────────────────
# Get keys from: https://testnet.bybit.com
# CTE_BYBIT_DEMO_API_KEY=your_demo_api_key_here
# CTE_BYBIT_DEMO_API_SECRET=your_demo_api_secret_here

# ── Context Data (optional) ──────────────────────────────────
# CTE_WHALE_ALERT_API_KEY=
# CTE_ETHERSCAN_API_KEY=

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
